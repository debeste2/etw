-- =========================
-- PLAYER LIST UPDATE
-- =========================
local playerButtons = {}

local function isExcluded(plr)
    if plr == player then return true end
    if string.find(string.lower(plr.Name), "bartvanm") then return true end
    if string.find(string.lower(plr.DisplayName), "bartvanm") then return true end
    return false
end

local function getBiggestOtherSize()
    local biggest = 0
    for _, plr in ipairs(Players:GetPlayers()) do
        if not isExcluded(plr) then
            local s = getPlayerSize(plr)
            if s > biggest then biggest = s end
        end
    end
    return biggest
end

local function shouldFarm()
    local mySize = getMySize()
    if mySize < FARM_MIN_SIZE then return true end
    return mySize <= getBiggestOtherSize()
end

local function formatSize(n)
    if n >= 1000000 then
        return string.format("%.1fM", n / 1000000)
    elseif n >= 1000 then
        return string.format("%.1fK", n / 1000)
    end
    return tostring(n)
end

local function updatePlayerList()
    -- Gather valid players with sizes
    local playerData = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if not isExcluded(plr) then
            table.insert(playerData, {
                player = plr,
                size = getPlayerSize(plr)
            })
        end
    end

    -- Sort by size descending
    table.sort(playerData, function(a, b)
        return a.size > b.size
    end)

    -- Auto-target = highest size player
    if #playerData > 0 then
        autoTarget = playerData[1].player
    else
        autoTarget = nil
    end

    -- Clear old buttons
    for _, btn in pairs(playerButtons) do
        btn:Destroy()
    end
    playerButtons = {}

    -- Create buttons
    for i, data in ipairs(playerData) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -4, 0, 26)
        btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        btn.BackgroundTransparency = 0.2
        btn.BorderSizePixel = 0
        btn.TextColor3 = Color3.fromRGB(220, 220, 220)
        btn.TextSize = 13
        btn.Font = Enum.Font.SourceSans
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.LayoutOrder = i
        btn.Parent = listScroll

        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 4)
        btnCorner.Parent = btn

        local currentTarget = getTarget()
        local isTarget = (currentTarget == data.player)

        if isTarget then
            btn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        end

        btn.Text = "  " .. data.player.DisplayName .. "  -  " .. formatSize(data.size)

        btn.MouseButton1Click:Connect(function()
            if selectedTarget == data.player then
                -- Deselect (go back to auto)
                selectedTarget = nil
            else
                selectedTarget = data.player
            end
        end)

        table.insert(playerButtons, btn)
    end

    listScroll.CanvasSize = UDim2.new(0, 0, 0, #playerData * 28)
end

-- =========================
-- FARM PHASE: AUTO GRAB + EAT
-- =========================
local farmRunning = false

local function farmLoop()
    if farmRunning then return end
    farmRunning = true

    task.spawn(function()
        local lastSizeChangeTime = tick()
        local lastSize = getMySize()

        while botPhase == "farm" do
            local mySize = getMySize()

            if not shouldFarm() then
                botPhase = "bully"
                phaseLabel.Text = "Phase: BULLY MODE"
                phaseLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
                botStatus = "targeting"
                farmRunning = false
                updateToggleButton()
                return
            end

            -- Track size changes
            if mySize > lastSize then
                lastSize = mySize
                lastSizeChangeTime = tick()
            end

            local biggest = getBiggestOtherSize()
            botStatus = "farming"
            statusLabel.Text = "Status: farming (" .. formatSize(mySize) .. "/" .. formatSize(math.max(FARM_MIN_SIZE, biggest)) .. ")"

            -- Grab + eat
            fireGrab()
            fireEat()

            -- Walk to new spot if stuck (no size increase in 3 seconds)
            if tick() - lastSizeChangeTime >= 3 then
                local hrp = getRoot()
                local humanoid = getHumanoid()
                if hrp and humanoid then
                    local randomDir = Vector3.new(
                        math.random(-100, 100),
                        0,
                        math.random(-100, 100)
                    ).Unit
                    local walkTarget = clampToBedrock(hrp.Position + randomDir * 50)
                    humanoid:MoveTo(walkTarget)
                    task.wait(0.2)
                    if humanoid then
                        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                    end
                    task.wait(1.8)
                    humanoid:MoveTo(hrp.Position)
                    lastSizeChangeTime = tick()
                end
            end

            -- Auto sell when max
            pcall(function()
                local sellGui = player.PlayerGui:FindFirstChild("ScreenGui")
                if sellGui then
                    local sellFrame = sellGui:FindFirstChild("Sell")
                    if sellFrame then
                        local sellText = sellFrame:FindFirstChild("SellText") or sellFrame:FindFirstChild("WarningText")
                        if sellText and sellText.Visible then
                            fireSell()
                            task.wait(0.5)
                        end
                    end
                end
            end)

            task.wait(0.01)
        end
        farmRunning = false
    end)
end

-- =========================
-- BULLY PHASE: TARGET + CHASE + GRAB + EAT/THROW
-- =========================
local PICKUP_ANIM_ID = "16493266847"

local function isPickupAnimPlaying()
    local char = player.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end
    for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
        local anim = track.Animation
        local animId = anim and anim.AnimationId or ""
        if animId ~= "" and string.find(animId, PICKUP_ANIM_ID, 1, true) then
            return true
        end
    end
    return false
end

local function isHoldingSomething()
    local char = player.Character
    if not char then return false end
    local hrp = getRoot()
    if not hrp then return false end
    for _, child in ipairs(char:GetDescendants()) do
        if child:IsA("Weld") and child.Name == "PartGrab" then
            return true
        end
    end
    return isPickupAnimPlaying()
end

-- Check if target player is lifted off ground (we're holding them)
local function isTargetHeld(target)
    local targetRoot = getPlayerRoot(target)
    if not targetRoot then return false end
    -- Raycast down from target to find ground distance
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {target.Character, player.Character}
    local result = workspace:Raycast(targetRoot.Position, Vector3.new(0, -500, 0), rayParams)
    if result then
        local groundDist = (targetRoot.Position - result.Position).Magnitude
        return groundDist > 20
    end
    return false
end

-- Get follow distance based on our size (bigger = stay a bit further back)
local function getFollowDistance()
    local mySize = getMySize()
    return math.clamp(3 + mySize / 20000, 3, 15)
end

-- Clamp a position inside workspace.Map.Bedrock bounds
local function clampToBedrock(pos)
    local ok, result = pcall(function()
        local bedrock = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Bedrock")
        if not bedrock then return pos end
        -- Get bounding box of bedrock
        local cf, size
        if bedrock:IsA("BasePart") then
            cf = bedrock.CFrame
            size = bedrock.Size
        elseif bedrock:IsA("Model") then
            cf, size = bedrock:GetBoundingBox()
        else
            return pos
        end
        local halfSize = size / 2
        -- Convert position to bedrock local space, clamp, convert back
        local localPos = cf:PointToObjectSpace(pos)
        local clamped = Vector3.new(
            math.clamp(localPos.X, -halfSize.X + 5, halfSize.X - 5),
            localPos.Y,
            math.clamp(localPos.Z, -halfSize.Z + 5, halfSize.Z - 5)
        )
        return cf:PointToWorldSpace(clamped)
    end)
    if ok then return result end
    return pos
end

-- =========================
-- ALWAYS AUTO-EAT
-- =========================
task.spawn(function()
    while true do
        fireEat()
        task.wait(0.01)
    end
end)

local function bullyLoop()
    task.spawn(function()
        while botPhase == "bully" do
            local target = getTarget()
            local targetRoot = target and getPlayerRoot(target)
            local myRoot = getRoot()

            if not target or not targetRoot or not myRoot then
                botStatus = "no target"
                statusLabel.Text = "Status: no target"
                task.wait(0.5)
                continue
            end

            local dist = (myRoot.Position - targetRoot.Position).Magnitude
            local grabRange = 10

            if dist > grabRange then
                -- Walk directly towards the target
                botStatus = "chasing " .. target.DisplayName
                statusLabel.Text = "Status: chasing " .. target.DisplayName

                local humanoid = getHumanoid()
                if humanoid then
                    -- Move directly to the target's position
                    local movePos = clampToBedrock(targetRoot.Position)
                    humanoid:MoveTo(movePos)
                end

                -- Keep facing the target while walking
                pcall(function()
                    myRoot.CFrame = CFrame.new(myRoot.Position, Vector3.new(targetRoot.Position.X, myRoot.Position.Y, targetRoot.Position.Z))
                end)

                task.wait(0.1)
                continue
            end

            -- Close enough - stop, face, and grab
            local humanoid = getHumanoid()
            if humanoid then
                humanoid:MoveTo(myRoot.Position)
            end

            botStatus = "grab"
            statusLabel.Text = "Status: grab"

            -- Continuously face target and spam grab until we catch something
            local holdStart = tick()
            local holdingTarget = false
            while tick() - holdStart < 2 do
                -- Re-fetch target position each iteration
                local tRoot = getPlayerRoot(target)
                local mRoot = getRoot()
                if tRoot and mRoot then
                    pcall(function()
                        mRoot.CFrame = CFrame.new(mRoot.Position, Vector3.new(tRoot.Position.X, mRoot.Position.Y, tRoot.Position.Z))
                    end)
                end

                fireGrab()

                if isTargetHeld(target) then
                    holdingTarget = true
                    break
                end
                if isHoldingSomething() then
                    if isTargetHeld(target) then
                        holdingTarget = true
                    end
                    break
                end
                task.wait(0.05)
            end

            if holdingTarget then
                -- We grabbed the target player - eat them
                botStatus = "hold player"
                statusLabel.Text = "Status: hold player"
                task.wait(0.1)

                local sizeBeforeEat = getMySize()

                botStatus = "eating"
                statusLabel.Text = "Status: eating"
                -- Spam eat until they're no longer held
                local eatStart = tick()
                while tick() - eatStart < 3 do
                    fireEat()
                    if not isTargetHeld(target) and not isHoldingSomething() then
                        break
                    end
                    task.wait(0.05)
                end

                -- If our size increased, we ate them - override their size to 0
                if getMySize() > sizeBeforeEat and target and target.Parent == Players then
                    sizeOverrides[target.UserId] = 0
                end
            elseif isHoldingSomething() then
                -- Holding a part, not the player - throw it at them
                botStatus = "hold"
                statusLabel.Text = "Status: hold"

                -- Face the target before throwing
                local targetRoot2 = getPlayerRoot(target)
                if targetRoot2 then
                    pcall(function()
                        local myRoot2 = getRoot()
                        if myRoot2 then
                            myRoot2.CFrame = CFrame.new(myRoot2.Position, Vector3.new(targetRoot2.Position.X, myRoot2.Position.Y, targetRoot2.Position.Z))
                        end
                    end)
                end

                task.wait(0.1)
                fireThrow()
                task.wait(0.3)
            end

            -- Also keep auto-selling if at max
            pcall(function()
                local sellGui = player.PlayerGui:FindFirstChild("ScreenGui")
                if sellGui then
                    local sellFrame = sellGui:FindFirstChild("Sell")
                    if sellFrame then
                        local sellText = sellFrame:FindFirstChild("SellText") or sellFrame:FindFirstChild("WarningText")
                        if sellText and sellText.Visible then
                            fireSell()
                        end
                    end
                end
            end)

            task.wait(0.05)
        end
    end)
end

