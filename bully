-- =========================
-- HELPERS
-- =========================
local function getRoot()
    local char = player.Character
    return char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
end

local function getHumanoid()
    local char = player.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function getMySize()
    local ls = player:FindFirstChild("leaderstats")
    if ls then
        local s = ls:FindFirstChild("Size")
        if s then return s.Value end
    end
    return 0
end

local sizeOverrides = {} -- UserId -> overridden size (0 after eating them)

local function getPlayerSize(plr)
    if sizeOverrides[plr.UserId] ~= nil then
        -- Clear override once leaderboard catches up (shows 0 or lower)
        local ls = plr:FindFirstChild("leaderstats")
        if ls then
            local s = ls:FindFirstChild("Size")
            if s and s.Value <= sizeOverrides[plr.UserId] then
                sizeOverrides[plr.UserId] = nil
                return s.Value
            end
        end
        return sizeOverrides[plr.UserId]
    end
    local ls = plr:FindFirstChild("leaderstats")
    if ls then
        local s = ls:FindFirstChild("Size")
        if s then return s.Value end
    end
    return 0
end

local function getPlayerRoot(plr)
    local char = plr.Character
    return char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
end

local function fireGrab()
    pcall(function()
        local char = player.Character
        if char then
            local events = char:FindFirstChild("Events")
            if events then
                local grab = events:FindFirstChild("Grab")
                if grab then grab:FireServer(false, false, false) end
            end
        end
    end)
end

local function fireEat()
    pcall(function()
        local char = player.Character
        if char then
            local events = char:FindFirstChild("Events")
            if events then
                local eat = events:FindFirstChild("Eat")
                if eat then eat:FireServer() end
            end
        end
    end)
end

local function fireThrow()
    pcall(function()
        local char = player.Character
        if char then
            local events = char:FindFirstChild("Events")
            if events then
                local throw = events:FindFirstChild("Throw")
                if throw then throw:FireServer() end
            end
        end
    end)
end

local function fireSell()
    pcall(function()
        local char = player.Character
        if char then
            local events = char:FindFirstChild("Events")
            if events then
                local sell = events:FindFirstChild("Sell")
                if sell then sell:FireServer() end
            end
        end
    end)
end

